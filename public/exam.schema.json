{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-kaoyan/exam.schema.json",
  "title": "AI考研试卷",
  "type": "object",
  "required": ["examId", "title", "subject", "description", "durationMinutes", "totalScore", "version", "sections"],
  "properties": {
    "examId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "durationMinutes": { "type": "number", "exclusiveMinimum": 0 },
    "totalScore": { "type": "number", "exclusiveMinimum": 0 },
    "version": { "type": "string", "minLength": 1 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sectionId", "title", "questions"],
        "properties": {
          "sectionId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "passage": { "type": "string" },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "type", "category", "knowledgePoint", "difficulty", "score", "question"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "type": { "enum": ["single_choice", "multiple_choice", "fill_blank", "translation", "essay"] },
                "category": { "type": "string", "minLength": 1 },
                "knowledgePoint": { "type": "string", "minLength": 1 },
                "difficulty": { "type": "string", "minLength": 1 },
                "score": { "type": "number", "exclusiveMinimum": 0 },
                "question": { "type": "string", "minLength": 1 },
                "options": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 5,
                  "items": {
                    "type": "object",
                    "required": ["key", "text"],
                    "properties": { "key": { "type": "string" }, "text": { "type": "string" } }
                  }
                },
                "correctAnswer": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
                "explanation": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
