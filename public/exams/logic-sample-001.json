      "questions": [
        {
          "id": "logic-q3",
          "type": "single_choice",
          "category": "论证逻辑",
          "knowledgePoint": "削弱论证",
          "difficulty": "中等",
          "score": 3,
          "question": "某公司发现，采用弹性工作制后员工满意度提高，因此认为弹性工作制必然提高工作效率。以下哪项最能削弱该结论？",
          "options": [
            { "key": "A", "text": "员工普遍欢迎弹性工作制" },
            { "key": "B", "text": "满意度调查由人力部门组织" },
            { "key": "C", "text": "同期项目按时交付率反而下降" },
            { "key": "D", "text": "其他公司也采用了弹性工作制" },
            { "key": "E", "text": "该公司员工平均年龄较低" }
          ],
          "correctAnswer": "C",
          "explanation": "按时交付率下降直接表明效率指标没有随满意度提高，削弱了从满意度到效率的推断。"
        },
        {
          "id": "logic-q4",
          "type": "single_choice",
          "category": "论证逻辑",
          "knowledgePoint": "加强论证",
          "difficulty": "中等",
          "score": 3,
          "question": "研究者认为，办公室增加绿植能减少员工压力。以下哪项最能加强该结论？",
          "options": [
            { "key": "A", "text": "绿植需要定期浇水" },
            { "key": "B", "text": "在其他条件相同的两组办公室中，有绿植组的压力指标显著更低" },
            { "key": "C", "text": "部分员工喜欢绿色" },
            { "key": "D", "text": "绿植采购费用较低" },
            { "key": "E", "text": "办公室采光通常很好" }
          ],
          "correctAnswer": "B",
          "explanation": "控制其他条件的对照结果直接支持绿植与压力降低之间的因果关系。"
        },
        {
          "id": "logic-q5",
          "type": "single_choice",
          "category": "分析推理",
          "knowledgePoint": "排序",
          "difficulty": "困难",
          "score": 3,
          "question": "甲、乙、丙三人依次发言，每人一次。甲不在第一位，乙在丙之前。以下哪种顺序符合条件？",
          "options": [
            { "key": "A", "text": "甲—乙—丙" },
            { "key": "B", "text": "甲—丙—乙" },
            { "key": "C", "text": "乙—甲—丙" },
            { "key": "D", "text": "丙—乙—甲" },
            { "key": "E", "text": "丙—甲—乙" }
          ],
          "correctAnswer": "C",
          "explanation": "甲不在第一位且乙在丙之前，乙—甲—丙同时满足两个条件。"
        }
      ]
    }
